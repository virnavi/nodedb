// ── Serialization ──────────────────────────────────────────────
UserPrefs _$UserPrefsFromMap(Map<String, dynamic> map) {
  return UserPrefs(
    theme: map['theme'] as String,
    notificationsEnabled: map['notificationsEnabled'] as bool,
  );
}

Map<String, dynamic> _$UserPrefsToMap(UserPrefs instance) {
  return {
    'theme': instance.theme,
    'notificationsEnabled': instance.notificationsEnabled,
  };
}

// ── Preferences Accessor ───────────────────────────────────────
abstract class UserPrefsPrefsBase {
  NoSqlEngine get _engine;

  String get storeName => 'user_prefses';

  String? getTheme() {
    final resp = _engine.prefGet(storeName, 'theme');
    if (resp is Map && resp['found'] == true) return resp['value'] as String;
    return null;
  }

  void setTheme(String value, {bool shareable = false}) {
    _engine.prefSet(storeName, 'theme', value, shareable: shareable);
  }

  bool removeTheme() {
    return _engine.prefRemove(storeName, 'theme');
  }

  bool? getNotificationsEnabled() {
    final resp = _engine.prefGet(storeName, 'notificationsEnabled');
    if (resp is Map && resp['found'] == true) return resp['value'] as bool;
    return null;
  }

  void setNotificationsEnabled(bool value, {bool shareable = false}) {
    _engine.prefSet(storeName, 'notificationsEnabled', value,
        shareable: shareable);
  }

  bool removeNotificationsEnabled() {
    return _engine.prefRemove(storeName, 'notificationsEnabled');
  }

  List<String> allKeys() => _engine.prefKeys(storeName);

  List<Map<String, dynamic>> shareableEntries() =>
      _engine.prefShareable(storeName);

  void removeAll() {
    for (final key in allKeys()) {
      _engine.prefRemove(storeName, key);
    }
  }
}

class UserPrefsPrefs extends UserPrefsPrefsBase {
  @override
  final NoSqlEngine _engine;
  UserPrefsPrefs(this._engine);
}
