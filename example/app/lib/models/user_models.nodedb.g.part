// ── Schema ─────────────────────────────────────────────────────
const _userSchema = NodeDbSchema(
  name: 'users',
  schema: 'public',
  singleton: false,
  type: 'collection',
  fields: [
    SchemaField('id', 'string', indexed: true, unique: true),
    SchemaField('name', 'string'),
    SchemaField('email', 'string', indexed: true, unique: true),
    SchemaField('avatarUrl', 'string'),
    SchemaField('createdAt', 'datetime'),
  ],
);

const _userSchemaJson = <String, dynamic>{
  'name': 'users',
  'schema': 'public',
  'type': 'collection',
  'required_fields': [
    'name',
    'email',
  ],
  'field_types': {
    'id': 'string',
    'name': 'string',
    'email': 'string',
    'avatarUrl': 'string',
    'createdAt': 'datetime',
  },
};

/// Fully qualified collection name: public.users
const userCollectionName = 'public.users';

// ── Serialization ──────────────────────────────────────────────
User _$UserFromMap(Map<String, dynamic> map) {
  return User(
    id: map['id'] as String,
    name: map['name'] as String,
    email: map['email'] as String,
    avatarUrl: map['avatarUrl'] as String?,
    createdAt: map['createdAt'] != null
        ? DateTime.parse(map['createdAt'] as String)
        : null,
  );
}

Map<String, dynamic> _$UserToMap(User instance) {
  return {
    'id': instance.id,
    'name': instance.name,
    'email': instance.email,
    'avatarUrl': instance.avatarUrl,
    'createdAt': instance.createdAt?.toIso8601String(),
  };
}

